@using TeachSpark.Web.Extensions
@model TeachSpark.Web.Services.Models.WorksheetContentResult
@{
    ViewData["Title"] = Model.GeneratedTitle;
}

<div class="container-fluid">
    <!-- Worksheet Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-start flex-wrap">
                <div class="mb-3 mb-md-0">
                    <h1 class="h2 text-primary">@Model.GeneratedTitle</h1>
                    <p class="text-muted mb-0">@Model.GeneratedDescription</p>
                </div>
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-outline-primary" onclick="copyFormatted()">
                        <i class="bi bi-clipboard me-1"></i>Copy Formatted
                    </button>
                    <button type="button" class="btn btn-outline-secondary" onclick="copyMarkdown()">
                        <i class="bi bi-code me-1"></i>Copy Markdown
                    </button>
                    <button type="button" class="btn btn-outline-success" onclick="printWorksheet()">
                        <i class="bi bi-printer me-1"></i>Print
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Mode Toggle -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="btn-group" role="group" aria-label="View mode toggle">
                <input type="radio" class="btn-check" name="viewMode" id="viewFormatted" checked>
                <label class="btn btn-outline-primary" for="viewFormatted">
                    <i class="bi bi-eye me-1"></i>Formatted View
                </label>

                <input type="radio" class="btn-check" name="viewMode" id="viewMarkdown">
                <label class="btn btn-outline-secondary" for="viewMarkdown">
                    <i class="bi bi-code-slash me-1"></i>Markdown Source
                </label>

                <input type="radio" class="btn-check" name="viewMode" id="viewPrint">
                <label class="btn btn-outline-success" for="viewPrint">
                    <i class="bi bi-printer me-1"></i>Student Version
                </label>
            </div>
        </div>
    </div>

    <!-- Content Display -->
    <div class="row">
        <div class="col-12">
            <!-- Formatted HTML View -->
            <div id="formatted-content" class="card border-0 shadow-sm bg-white"
                style="max-width: 8.5in; margin: 0 auto;">
                <div class="card-body p-4" style="font-family: 'Georgia', serif; line-height: 1.6;">
                    @Html.Raw(Model.RenderedHtml)
                </div>
            </div>

            <!-- Markdown Source View -->
            <div id="markdown-content" class="d-none">
                <div class="card shadow-sm">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Markdown Source</h5>
                        <small class="text-muted">Copy this text to reuse or edit in any Markdown editor</small>
                    </div>
                    <div class="card-body p-0">
                        <pre class="language-markdown mb-0 p-3 bg-light border-0"
                            style="font-size: 0.9rem; max-height: 400px; overflow-y: auto;"><code class="language-markdown">@Model.MarkdownContent</code></pre>
                    </div>
                </div>
            </div>

            <!-- Student Print Version -->
            <div id="print-content" class="card border-0 shadow-sm bg-white d-none"
                style="max-width: 8.5in; margin: 0 auto;">
                <div class="card-body p-4" style="font-family: 'Georgia', serif; line-height: 1.6;">
                    <!-- This will be populated via JavaScript -->
                </div>
            </div>
        </div>
    </div>

    <!-- Worksheet Metadata -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 bg-light shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-primary">
                        <i class="bi bi-info-circle me-2"></i>Worksheet Information
                    </h6>
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <small class="text-muted fw-bold">Generated:</small><br>
                            <span class="fw-semibold">@DateTime.Now.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="col-md-3 mb-2">
                            <small class="text-muted fw-bold">Model Used:</small><br>
                            <span class="fw-semibold">@Model.LlmModel</span>
                        </div>
                        <div class="col-md-3 mb-2">
                            <small class="text-muted fw-bold">Generation Time:</small><br>
                            <span class="fw-semibold">@Model.GenerationTime.TotalSeconds.ToString("F1")s</span>
                        </div>
                        <div class="col-md-3 mb-2">
                            <small class="text-muted fw-bold">Cost:</small><br>
                            <span class="fw-semibold">$@Model.GenerationCost.ToString("F4")</span>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-md-4 mb-2">
                            <small class="text-muted fw-bold">Questions:</small><br>
                            <span class="fw-semibold">@Model.ExtractedQuestions.Count</span>
                        </div>
                        <div class="col-md-4 mb-2">
                            <small class="text-muted fw-bold">Estimated Duration:</small><br>
                            <span class="fw-semibold">@Model.EstimatedDurationMinutes min</span>
                        </div>
                        <div class="col-md-4 mb-2">
                            <small class="text-muted fw-bold">Confidence Score:</small><br>
                            <span class="fw-semibold">@((Model.ConfidenceScore * 100).ToString("F0"))%</span>
                        </div>
                    </div>
                    @if (Model.Warnings.Any())
                    {
                        <div class="row mt-3">
                            <div class="col-12">
                                <small class="text-muted fw-bold">
                                    <i class="bi bi-exclamation-triangle me-1"></i>Warnings:
                                </small><br>
                                @foreach (var warning in Model.Warnings)
                                {
                                    <span class="badge bg-warning text-dark me-1 mb-1">@warning</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="row mt-4 mb-4">
        <div class="col-12 text-center">
            <a href="@Url.Action("Create")" class="btn btn-primary me-2">
                <i class="bi bi-plus-circle me-1"></i>Generate Another
            </a>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back to Generator
            </a>
        </div>
    </div>
</div>

<!-- Hidden elements for copying -->
<textarea id="markdown-copy-source" class="d-none">@Model.MarkdownContent</textarea>

@section Scripts {
    <script>
        // View mode switching
        document.querySelectorAll('input[name="viewMode"]').forEach(radio =>
        {
            radio.addEventListener('change', function ()
            {
                switchViewMode(this.id);
            });
        });

        function switchViewMode(mode)
        {
            // Hide all content views
            document.getElementById('formatted-content').classList.add('d-none');
            document.getElementById('markdown-content').classList.add('d-none');
            document.getElementById('print-content').classList.add('d-none');

            switch (mode)
            {
                case 'viewFormatted':
                    document.getElementById('formatted-content').classList.remove('d-none');
                    break;
                case 'viewMarkdown':
                    document.getElementById('markdown-content').classList.remove('d-none');
                    break;
                case 'viewPrint':
                    loadPrintVersion();
                    document.getElementById('print-content').classList.remove('d-none');
                    break;
            }
        }

        async function loadPrintVersion()
        {
            const printContent = document.getElementById('print-content').querySelector('.card-body');
            if (printContent.innerHTML.trim() === '')
            {
                try
                {
                    // For generated worksheets, create a student-friendly version by removing answer keys
                    const formattedContent = document.getElementById('formatted-content').querySelector('.card-body').innerHTML;

                    // Simple regex to remove answer key sections
                    const studentVersion = formattedContent
                        .replace(/<h[1-6][^>]*>.*?answer.*?key.*?<\/h[1-6]>/gi, '')
                        .replace(/<div[^>]*answer[^>]*>.*?<\/div>/gi, '')
                        .replace(/<!--.*?answer.*?-->/gi, '');

                            printContent.innerHTML = studentVersion;
                } catch (error)
                {
                    printContent.innerHTML = '<div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-2"></i>Unable to load student version</div>';
                }
            }
        }

        function copyFormatted()
        {
            const content = document.getElementById('formatted-content').querySelector('.card-body');
            if (navigator.clipboard && window.getSelection)
            {
                const selection = window.getSelection();
                const range = document.createRange();
                range.selectNodeContents(content);
                selection.removeAllRanges();
                selection.addRange(range);

                try
                {
                    document.execCommand('copy');
                    showToast('Formatted content copied to clipboard!', 'success');
                } catch (err)
                {
                    showToast('Failed to copy content', 'danger');
                }

                selection.removeAllRanges();
            }
        }

        function copyMarkdown()
        {
            const markdown = document.getElementById('markdown-copy-source').value;
            if (navigator.clipboard)
            {
                navigator.clipboard.writeText(markdown).then(() =>
                {
                    showToast('Markdown copied to clipboard!', 'success');
                }).catch(() =>
                {
                    showToast('Failed to copy markdown', 'danger');
                });
            }
        }

        function printWorksheet()
        {
            // Switch to print view first if not already active
            const printRadio = document.getElementById('viewPrint');
            if (!printRadio.checked)
            {
                printRadio.checked = true;
                switchViewMode('viewPrint');

                // Wait a moment for content to load, then print
                setTimeout(() =>
                {
                    window.print();
                }, 500);
            } else
            {
                window.print();
            }
        }

        function showToast(message, type)
        {
            // Create toast container if it doesn't exist
            let toastContainer = document.getElementById('toast-container');
            if (!toastContainer)
            {
                toastContainer = document.createElement('div');
                toastContainer.id = 'toast-container';
                toastContainer.className = 'toast-container position-fixed top-0 end-0 p-3';
                toastContainer.style.zIndex = '9999';
                document.body.appendChild(toastContainer);
            }

            // Create toast
            const toastEl = document.createElement('div');
            toastEl.className = `toast align-items-center text-white bg-${type} border-0`;
            toastEl.setAttribute('role', 'alert');
            toastEl.innerHTML = `
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>
                            ${message}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                    </div>
                `;

            toastContainer.appendChild(toastEl);

            // Initialize and show toast
            const toast = new bootstrap.Toast(toastEl, { delay: 3000 });
            toast.show();

            // Remove from DOM after hidden
            toastEl.addEventListener('hidden.bs.toast', () =>
            {
                toastEl.remove();
            });
        }        // Print styles
        const printStyles = `
                @@media print {
                    .btn-group, .card-title, .row.mt-4, .btn, nav, footer {
                        display: none !important;
                    }
                    .card {
                        border: none !important;
                        box-shadow: none !important;
                    }
                    .card-body {
                        padding: 0 !important;
                    }
                    body {
                        background: white !important;
                    }
                }
            `;

        // Add print styles
        const styleSheet = document.createElement('style');
        styleSheet.textContent = printStyles;
        document.head.appendChild(styleSheet);
    </script>
}

