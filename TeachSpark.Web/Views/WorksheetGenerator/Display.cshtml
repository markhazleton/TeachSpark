@using TeachSpark.Web.Extensions
@model TeachSpark.Web.Services.Models.WorksheetContentResult
@{
    ViewData["Title"] = Model.GeneratedTitle;
}

<div class="container-fluid">
    <!-- Worksheet Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-start">                <div>
                    <h1 class="h2">@Model.GeneratedTitle</h1>
                    <p class="text-muted mb-0">@Model.GeneratedDescription</p>
                </div>
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-outline-primary" onclick="copyFormatted()">
                        <i class="bi bi-clipboard me-1"></i>Copy Formatted
                    </button>
                    <button type="button" class="btn btn-outline-secondary" onclick="copyMarkdown()">
                        <i class="bi bi-code me-1"></i>Copy Markdown
                    </button>
                    <button type="button" class="btn btn-outline-success" onclick="printWorksheet()">
                        <i class="bi bi-printer me-1"></i>Print
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Mode Toggle -->
    <div class="row mb-3">
        <div class="col-12">
            <div class="btn-group" role="group" aria-label="View mode toggle">
                <input type="radio" class="btn-check" name="viewMode" id="viewFormatted" checked>
                <label class="btn btn-outline-primary" for="viewFormatted">
                    <i class="bi bi-eye me-1"></i>Formatted View
                </label>

                <input type="radio" class="btn-check" name="viewMode" id="viewMarkdown">
                <label class="btn btn-outline-secondary" for="viewMarkdown">
                    <i class="bi bi-code-slash me-1"></i>Markdown Source
                </label>

                <input type="radio" class="btn-check" name="viewMode" id="viewPrint">
                <label class="btn btn-outline-success" for="viewPrint">
                    <i class="bi bi-printer me-1"></i>Student Version
                </label>
            </div>
        </div>
    </div>

    <!-- Content Display -->
    <div class="row">
        <div class="col-12">
            <!-- Formatted HTML View -->
            <div id="formatted-content" class="worksheet-content border rounded p-4 bg-white">
                @Html.Raw(Model.RenderedHtml)
            </div>            <!-- Markdown Source View -->
            <div id="markdown-content" class="d-none">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Markdown Source</h5>
                        <small class="text-muted">Copy this text to reuse or edit in any Markdown editor</small>
                    </div>
                    <div class="card-body p-0">
                        <pre
                            class="language-markdown mb-0"><code class="language-markdown">@Model.MarkdownContent</code></pre>
                    </div>
                </div>
            </div>

            <!-- Student Print Version -->
            <div id="print-content" class="worksheet-content border rounded p-4 bg-white d-none">
                <!-- This will be populated via JavaScript -->
            </div>
        </div>
    </div>    <!-- Worksheet Metadata -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 bg-light">
                <div class="card-body">
                    <h6 class="card-title">Worksheet Information</h6>
                    <div class="row">
                        <div class="col-md-3">
                            <small class="text-muted">Generated:</small><br>
                            <span>@DateTime.Now.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Model Used:</small><br>
                            <span>@Model.LlmModel</span>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Generation Time:</small><br>
                            <span>@Model.GenerationTime.TotalSeconds.ToString("F1")s</span>
                        </div>
                        <div class="col-md-3">
                            <small class="text-muted">Cost:</small><br>
                            <span>$@Model.GenerationCost.ToString("F4")</span>
                        </div>
                    </div>
                    @if (Model.Warnings.Any())
                    {
                        <div class="row mt-2">
                            <div class="col-12">
                                <small class="text-muted">Warnings:</small><br>
                                @foreach (var warning in Model.Warnings)
                                {
                                    <span class="badge bg-warning text-dark me-1">@warning</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hidden elements for copying -->
<textarea id="markdown-copy-source" class="d-none">@Model.MarkdownContent</textarea>
<div id="print-copy-source" class="d-none"></div>

@section Styles {
    <style>
        .worksheet-content {
            font-family: 'Georgia', serif;
            line-height: 1.6;
            max-width: 8.5in;
            margin: 0 auto;
        }

        .worksheet-content h1 {
            text-align: center;
            border-bottom: 2px solid #333;
            padding-bottom: 10px;
        }

        .worksheet-content h2 {
            color: #2c5aa0;
            margin-top: 2rem;
        }

        .worksheet-content table {
            width: 100%;
            margin: 1rem 0;
        }

        .worksheet-content .answer-key-header {
            background-color: #f8f9fa;
            padding: 0.5rem;
            border-left: 4px solid #007bff;
        }

        pre code {
            font-size: 0.9rem;
            max-height: 400px;
            overflow-y: auto;
        }

        @@media print {

            .btn-group,
            .card-title,
            .card,
            .row.mt-4 {
                display: none !important;
            }

            .worksheet-content {
                border: none !important;
                box-shadow: none !important;
                margin: 0 !important;
                padding: 0 !important;
            }
        }
    </style>
}

@section Scripts {
    <script>
        // View mode switching
        document.querySelectorAll('input[name="viewMode"]').forEach(radio =>
        {
            radio.addEventListener('change', function ()
            {
                switchViewMode(this.id);
            });
        });

        function switchViewMode(mode)
        {
            // Hide all content views
            document.getElementById('formatted-content').classList.add('d-none');
            document.getElementById('markdown-content').classList.add('d-none');
            document.getElementById('print-content').classList.add('d-none');

            switch (mode)
            {
                case 'viewFormatted':
                    document.getElementById('formatted-content').classList.remove('d-none');
                    break;
                case 'viewMarkdown':
                    document.getElementById('markdown-content').classList.remove('d-none');
                    break;
                case 'viewPrint':
                    loadPrintVersion();
                    document.getElementById('print-content').classList.remove('d-none');
                    break;
            }
        }        async function loadPrintVersion()
        {
            const printContent = document.getElementById('print-content');
            if (printContent.innerHTML.trim() === '')
            {
                try
                {
                    // For generated worksheets, create a student-friendly version by removing answer keys
                    const formattedContent = document.getElementById('formatted-content').innerHTML;
                    
                    // Simple regex to remove answer key sections
                    const studentVersion = formattedContent
                        .replace(/<h[1-6][^>]*>.*?answer.*?key.*?<\/h[1-6]>/gi, '')
                        .replace(/<div[^>]*answer[^>]*>.*?<\/div>/gi, '')
                        .replace(/<!--.*?answer.*?-->/gi, '');
                    
                    printContent.innerHTML = studentVersion;
                } catch (error)
                {
                    printContent.innerHTML = '<div class="alert alert-warning">Unable to load student version</div>';
                }
            }
        }

        function copyFormatted()
        {
            const content = document.getElementById('formatted-content');
            if (navigator.clipboard && window.getSelection)
            {
                const selection = window.getSelection();
                const range = document.createRange();
                range.selectNodeContents(content);
                selection.removeAllRanges();
                selection.addRange(range);

                try
                {
                    document.execCommand('copy');
                    showToast('Formatted content copied to clipboard!', 'success');
                } catch (err)
                {
                    showToast('Failed to copy content', 'error');
                }

                selection.removeAllRanges();
            }
        }

        function copyMarkdown()
        {
            const markdown = document.getElementById('markdown-copy-source').value;
            if (navigator.clipboard)
            {
                navigator.clipboard.writeText(markdown).then(() =>
                {
                    showToast('Markdown copied to clipboard!', 'success');
                }).catch(() =>
                {
                    showToast('Failed to copy markdown', 'error');
                });
            }
        }

        function printWorksheet()
        {
            window.print();
        }

        function showToast(message, type)
        {
            // Simple toast notification
            const toast = document.createElement('div');
            toast.className = `alert alert-${type === 'success' ? 'success' : 'danger'} position-fixed top-0 end-0 m-3`;
            toast.style.zIndex = '9999';
            toast.textContent = message;
            document.body.appendChild(toast);

            setTimeout(() =>
            {
                toast.remove();
            }, 3000);
        }
    </script>
}

                           


           
           
           
        
           
        
           
       
           
               
               
       
           
