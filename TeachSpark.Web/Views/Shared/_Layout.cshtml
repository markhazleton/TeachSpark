@inject TeachSpark.Web.IAssetsService AssetsService
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TeachSpark.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="@AssetsService.GetAssetPath("site.css")" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-light border-bottom">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">TeachSpark.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Plan">Plan</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Account"
                                    asp-action="Dashboard">Dashboard</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main>
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="bg-light py-3 border-top">
        <div class="container">
            <span class="text-muted">&copy; 2025 - TeachSpark.Web - <a asp-area="" asp-controller="Home"
                    asp-action="Privacy" class="text-muted">Privacy</a></span>
        </div>
    </footer>
    <script src="@AssetsService.GetAssetPath("site.js")"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>

           