@model ApplicationUser
@{
    ViewData["Title"] = "My Profile";
}

<div class="row">
    <div class="col-md-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Profile</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="bi bi-person-circle display-1 text-primary"></i>
                </div>
                <h5 class="card-title">@Model.FirstName @Model.LastName</h5>
                <p class="card-text text-muted">@Model.Email</p>
                <div class="d-grid gap-2">
                    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-primary">Edit Profile</a>
                    <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword"
                        class="btn btn-outline-secondary">Change Password</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Profile Details</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-sm-3">
                        <strong>First Name:</strong>
                    </div>
                    <div class="col-sm-9">
                        @(Model.FirstName ?? "Not provided")
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-3">
                        <strong>Last Name:</strong>
                    </div>
                    <div class="col-sm-9">
                        @(Model.LastName ?? "Not provided")
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-3">
                        <strong>Email Address:</strong>
                    </div>
                    <div class="col-sm-9">
                        @Model.Email
                        @if (Model.EmailConfirmed)
                        {
                            <span class="badge bg-success ms-2">Verified</span>
                        }
                        else
                        {
                            <span class="badge bg-warning ms-2">Unverified</span>
                        }
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-3">
                        <strong>Username:</strong>
                    </div>
                    <div class="col-sm-9">
                        @Model.UserName
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-3">
                        <strong>Phone Number:</strong>
                    </div>
                    <div class="col-sm-9">
                        @(Model.PhoneNumber ?? "Not provided")
                        @if (!string.IsNullOrEmpty(Model.PhoneNumber) && Model.PhoneNumberConfirmed)
                        {
                            <span class="badge bg-success ms-2">Verified</span>
                        }
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-3">
                        <strong>Member Since:</strong>
                    </div>
                    <div class="col-sm-9">
                        @Model.CreatedAt.ToString("MMMM dd, yyyy")
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-3">
                        <strong>Last Login:</strong>
                    </div>
                    <div class="col-sm-9">
                        @(Model.LastLoginAt?.ToString("MMMM dd, yyyy 'at' HH:mm") ?? "Never")
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-3">
                        <strong>Account Status:</strong>
                    </div>
                    <div class="col-sm-9">
                        <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-3">
                        <strong>Two-Factor Auth:</strong>
                    </div>
                    <div class="col-sm-9">
                        <span class="badge @(Model.TwoFactorEnabled ? "bg-success" : "bg-secondary")">
                            @(Model.TwoFactorEnabled ? "Enabled" : "Disabled")
                        </span>
                        @if (!Model.TwoFactorEnabled)
                        {
                            <a asp-area="Identity" asp-page="/Account/Manage/TwoFactorAuthentication"
                                class="btn btn-sm btn-outline-primary ms-2">Enable</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

                       
                               