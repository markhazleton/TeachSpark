@using TeachSpark.Web.Data.Entities
@model ApplicationUser
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row">
    <div class="col-md-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Welcome back, @Model.FirstName @Model.LastName</h1>
            <div class="text-muted">
                <small>Last login: @(Model.LastLoginAt?.ToString("MMM dd, yyyy HH:mm") ?? "First time")</small>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="bi bi-person-circle display-4 text-primary"></i>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="card-title mb-1">Profile</h5>
                        <p class="card-text text-muted mb-2">Manage your account information</p>
                        <a asp-action="Profile" class="btn btn-outline-primary btn-sm">View Profile</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="bi bi-gear display-4 text-success"></i>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="card-title mb-1">Settings</h5>
                        <p class="card-text text-muted mb-2">Update your preferences</p>
                        <a asp-area="Identity" asp-page="/Account/Manage/Index"
                            class="btn btn-outline-success btn-sm">Manage Account</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="bi bi-shield-check display-4 text-warning"></i>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h5 class="card-title mb-1">Security</h5>
                        <p class="card-text text-muted mb-2">Change password and security settings</p>
                        <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword"
                            class="btn btn-outline-warning btn-sm">Security</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Account Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-muted">Personal Details</h6>
                        <p><strong>Name:</strong> @Model.FirstName @Model.LastName</p>
                        <p><strong>Email:</strong> @Model.Email</p>
                        <p><strong>Username:</strong> @Model.UserName</p>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted">Account Status</h6>
                        <p><strong>Status:</strong>
                            <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")">
                                @(Model.IsActive ? "Active" : "Inactive")
                            </span>
                        </p>
                        <p><strong>Email Confirmed:</strong>
                            <span class="badge @(Model.EmailConfirmed ? "bg-success" : "bg-warning")">
                                @(Model.EmailConfirmed ? "Verified" : "Pending")
                            </span>
                        </p>
                        <p><strong>Member Since:</strong> @Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

                           
                           