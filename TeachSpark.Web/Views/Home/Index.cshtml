@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to TeachSpark.Web</h1>
    <p class="lead">A modern ASP.NET Core MVC application with Bootstrap 5 and custom build process</p>
    
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-code-square display-4 text-primary-custom mb-3"></i>
                    <h5 class="card-title">Modern Development</h5>
                    <p class="card-text">Built with .NET 9, Bootstrap 5, and modern tooling including Webpack and SCSS.</p>
                    <button class="btn btn-primary-custom" data-bs-toggle="tooltip" title="Click me!">
                        <i class="bi bi-arrow-right"></i> Learn More
                    </button>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-palette display-4 text-success mb-3"></i>
                    <h5 class="card-title">Beautiful UI</h5>
                    <p class="card-text">Responsive design with Bootstrap Icons and custom styling for a professional look.</p>
                    <button class="btn btn-success">
                        <i class="bi bi-eye"></i> View Design
                    </button>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-lightning-charge display-4 text-warning mb-3"></i>
                    <h5 class="card-title">Fast & Efficient</h5>
                    <p class="card-text">Optimized build process with minified CSS and JS for optimal performance.</p>
                    <button class="btn btn-warning">
                        <i class="bi bi-speedometer2"></i> Performance
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-5">
        <h3>Available Features <i class="bi bi-check-circle-fill text-success"></i></h3>
        <div class="d-flex justify-content-center flex-wrap gap-3 mt-3">
            <span class="badge bg-primary fs-6">
                <i class="bi bi-bootstrap"></i> Bootstrap 5
            </span>
            <span class="badge bg-success fs-6">
                <i class="bi bi-palette"></i> Bootstrap Icons
            </span>
            <span class="badge bg-info fs-6">
                <i class="bi bi-filetype-scss"></i> SCSS Support
            </span>
            <span class="badge bg-warning text-dark fs-6">
                <i class="bi bi-webpack"></i> Webpack Build
            </span>
            <span class="badge bg-danger fs-6">
                <i class="bi bi-microsoft"></i> .NET 9
            </span>
        </div>
    </div>
    
    <div class="mt-4">
        <p>Learn about <a href="https://learn.microsoft.com/aspnet/core" class="text-decoration-none">
            <i class="bi bi-book"></i> building Web apps with ASP.NET Core
        </a>.</p>
    </div>
</div>

<div id="alert-container"></div>
