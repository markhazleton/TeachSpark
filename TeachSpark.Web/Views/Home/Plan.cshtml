<!-- API Endpoints -->
<div class="row mb-5">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom-0 pt-4">
                <h2 class="h3 mb-0 text-primary">
                    <i class="bi bi-code-slash me-2"></i>RESTful API Endpoints
                </h2>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-lg-6">
                        <div class="card border">
                            <div class="card-header bg-light">
                                <h6 class="mb-0">Worksheet Operations</h6>
                            </div>
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <code class="small">POST /api/v1/worksheets/generate</code>
                                    <span class="badge bg-success">CREATE</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <code class="small">GET /api/v1/worksheets/{id}</code>
                                    <span class="badge bg-primary">READ</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <code class="small">POST /api/v1/export/{format}</code>
                                    <span class="badge bg-info">EXPORT</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="card border">
                            <div class="card-header bg-light">
                                <h6 class="mb-0">Resources & Standards</h6>
                            </div>
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <code class="small">GET /api/v1/templates</code>
                                    <span class="badge bg-primary">READ</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <code class="small">GET /api/v1/standards</code>
                                    <span class="badge bg-primary">READ</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <code class="small">GET /api/v1/bloom-levels</code>
                                    <span class="badge bg-primary">READ</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

