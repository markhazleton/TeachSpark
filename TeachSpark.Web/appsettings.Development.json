{
    "Logging": {
        "LogLevel": {
            "Default": "Debug",
            "Microsoft.AspNetCore": "Information"
        }
    },
    "LlmConfiguration": {
        "ApiKey": "your-development-api-key-here",
        "MaxCostPerRequest": 2.0,
        "DailyCostLimit": 100.0,
        "RequestsPerMinute": 30,
        "RequestsPerDay": 2000,
        "TimeoutSeconds": 120,
        "CacheExpirationMinutes": 30
    },
    "WorksheetGeneration": {
        "RequireStandardsAlignment": false,
        "EnableContentValidation": true
    }
}
