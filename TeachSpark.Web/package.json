{
    "name": "teachspark.web",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "build": "webpack --mode=production",
        "build:dev": "webpack --mode=development",
        "build:analyze": "webpack --mode=production --env analyze",
        "dev": "webpack serve --mode=development --open",
        "watch": "webpack --mode=development --watch",
        "clean": "rimraf wwwroot/css wwwroot/js wwwroot/fonts wwwroot/images",
        "clean:all": "rimraf wwwroot && mkdir wwwroot",
        "lint": "eslint src/**/*.js",
        "lint:fix": "eslint src/**/*.js --fix",
        "lint:css": "stylelint \"src/**/*.{css,scss}\"",
        "lint:css:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
        "format": "prettier --write \"src/**/*.{js,scss,css}\"",
        "format:check": "prettier --check \"src/**/*.{js,scss,css}\"",
        "quality": "npm run lint && npm run lint:css && npm run format:check",
        "quality:fix": "npm run lint:fix && npm run lint:css:fix && npm run format",
        "prebuild": "npm run quality",
        "test": "echo \"Add your tests here\" && exit 0",
        "start": "npm run dev",
        "prepare": "husky"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/plugin-proposal-dynamic-import": "^7.18.6",
        "@babel/plugin-syntax-dynamic-import": "^7.8.3",
        "@babel/preset-env": "^7.29.2",
        "@eslint/js": "^10.0.1",
        "autoprefixer": "^10.4.27",
        "babel-loader": "^10.1.1",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^14.0.0",
        "core-js": "^3.49.0",
        "css-loader": "^7.1.4",
        "css-minimizer-webpack-plugin": "^8.0.0",
        "eslint": "^10.1.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "mini-css-extract-plugin": "^2.10.2",
        "postcss": "^8.5.8",
        "postcss-loader": "^8.2.1",
        "postcss-preset-env": "^11.2.0",
        "prettier": "^3.8.1",
        "rimraf": "^6.1.3",
        "sass": "^1.98.0",
        "sass-loader": "^16.0.7",
        "style-loader": "^4.0.0",
        "stylelint": "^17.6.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "terser-webpack-plugin": "^5.4.0",
        "webpack": "^5.105.4",
        "webpack-bundle-analyzer": "^5.3.0",
        "webpack-cli": "^7.0.2",
        "webpack-dev-server": "^5.2.3",
        "webpack-manifest-plugin": "^6.0.1",
        "webpack-merge": "^6.0.1"
    },
