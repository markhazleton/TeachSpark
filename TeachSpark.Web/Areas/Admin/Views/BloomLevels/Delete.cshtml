@model TeachSpark.Web.Data.Entities.BloomLevel

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0 text-danger">
                <i class="bi bi-exclamation-triangle"></i>
                Delete Bloom Level
            </h1>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">
                <i class="bi bi-exclamation-triangle-fill"></i>
                Confirm Deletion
            </h4>
            <p>Are you sure you want to delete this Bloom Level? This action cannot be undone.</p>
            <hr>
            <p class="mb-0">
                <strong>Note:</strong> You can only delete Bloom Levels that are not currently being used by any worksheets.
            </p>
        </div>

        <div class="card">
            <div class="card-header" style="background-color: @Model.ColorCode; color: white;">
                <h5 class="card-title mb-0">
                    <i class="bi bi-tag"></i>
                    @Model.Name (Level @Model.Order)
                </h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Order:</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-primary fs-6">@Model.Order</span>
                    </dd>
                    
                    <dt class="col-sm-3">Description:</dt>
                    <dd class="col-sm-9">@Model.Description</dd>
                    
                    <dt class="col-sm-3">Action Verbs:</dt>
                    <dd class="col-sm-9">
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var verb in Model.ActionVerbs.Split(',', StringSplitOptions.RemoveEmptyEntries).Take(5))
                            {
                                <span class="badge bg-secondary">@verb.Trim()</span>
                            }
                            @if (Model.ActionVerbs.Split(',', StringSplitOptions.RemoveEmptyEntries).Length > 5)
                            {
                                <span class="text-muted">... and @(Model.ActionVerbs.Split(',', StringSplitOptions.RemoveEmptyEntries).Length - 5) more</span>
                            }
                        </div>
                    </dd>
                    
                    <dt class="col-sm-3">Color Code:</dt>
                    <dd class="col-sm-9">
                        <span class="badge" style="background-color: @Model.ColorCode; color: white;">
                            @Model.ColorCode
                        </span>
                    </dd>
                    
                    <dt class="col-sm-3">Associated Worksheets:</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-info fs-6">@Model.Worksheets.Count</span>
                        @if (Model.Worksheets.Any())
                        {
                            <span class="text-danger ms-2">
                                <i class="bi bi-exclamation-circle"></i>
                                Cannot delete - currently in use
                            </span>
                        }
                    </dd>
                </dl>

                @if (!string.IsNullOrEmpty(Model.Examples))
                {
                    <div class="mt-3">
                        <strong>Examples:</strong>
                        <div class="bg-light p-3 rounded mt-2">
                            <p class="mb-0">@Model.Examples</p>
                        </div>
                    </div>
                }

                @if (Model.Worksheets.Any())
                {
                    <div class="alert alert-warning mt-4" role="alert">
                        <h6 class="alert-heading">
                            <i class="bi bi-info-circle"></i>
                            Cannot Delete - Worksheets Found
                        </h6>
                        <p class="mb-2">This Bloom Level is currently being used by the following worksheets:</p>
                        <ul class="mb-0">
                            @foreach (var worksheet in Model.Worksheets.Take(5))
                            {
                                <li>
                                    <a asp-controller="Worksheets" asp-action="Details" asp-route-id="@worksheet.Id" class="text-decoration-none">
                                        @worksheet.Title
                                    </a>
                                    <small class="text-muted">(by @worksheet.User.Email)</small>
                                </li>
                            }
                            @if (Model.Worksheets.Count > 5)
                            {
                                <li class="text-muted">... and @(Model.Worksheets.Count - 5) more worksheets</li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            @if (Model.Worksheets.Any())
            {
                <button type="button" class="btn btn-danger" disabled>
                    <i class="bi bi-slash-circle"></i> Cannot Delete - In Use
                </button>
            }
            else
            {
                <form asp-action="Delete" method="post" class="d-inline">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger" 
                            onclick="return confirm('Are you absolutely sure you want to delete this Bloom Level? This action cannot be undone.')">
                        <i class="bi bi-trash"></i> Yes, Delete This Bloom Level
                    </button>
                </form>
            }
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-info">
                <i class="bi bi-eye"></i> View Details
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-x-circle"></i> Cancel
            </a>
        </div>
    </div>
</div>
