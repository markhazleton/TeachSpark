@model TeachSpark.Web.Data.Entities.BloomLevel

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">
                <i class="bi bi-plus-circle text-success"></i>
                Create New Bloom Level
            </h1>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-diagram-3"></i>
                    Bloom Level Information
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Name" class="form-label">
                                    <i class="bi bi-tag"></i> Name <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Name" class="form-control" placeholder="e.g., Remember, Understand, Apply" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label asp-for="Order" class="form-label">
                                    <i class="bi bi-sort-numeric-up"></i> Order <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Order" class="form-control" type="number" min="1" max="10" />
                                <span asp-validation-for="Order" class="text-danger"></span>
                                <div class="form-text">Order in Bloom's hierarchy (1-6)</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="mb-3">
                                <label asp-for="ColorCode" class="form-label">
                                    <i class="bi bi-palette"></i> Color Code
                                </label>
                                <input asp-for="ColorCode" class="form-control" type="color" />
                                <span asp-validation-for="ColorCode" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">
                            <i class="bi bi-card-text"></i> Description <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="3" 
                                  placeholder="Describe what this cognitive level represents..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ActionVerbs" class="form-label">
                            <i class="bi bi-list-ul"></i> Action Verbs <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="ActionVerbs" class="form-control" rows="3" 
                                  placeholder="Comma-separated list of action verbs (e.g., define, list, identify, recall)"></textarea>
                        <span asp-validation-for="ActionVerbs" class="text-danger"></span>
                        <div class="form-text">Enter action verbs separated by commas</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Examples" class="form-label">
                            <i class="bi bi-lightbulb"></i> Examples
                        </label>
                        <textarea asp-for="Examples" class="form-control" rows="3" 
                                  placeholder="Provide examples of activities or questions for this level..."></textarea>
                        <span asp-validation-for="Examples" class="text-danger"></span>
                    </div>

                    <div class="card bg-light mb-3">
                        <div class="card-body">
                            <h6 class="card-title">
                                <i class="bi bi-info-circle text-info"></i>
                                Bloom's Taxonomy Reference
                            </h6>
                            <p class="card-text small mb-0">
                                <strong>Remember (1):</strong> Retrieving knowledge from memory<br>
                                <strong>Understand (2):</strong> Constructing meaning from messages<br>
                                <strong>Apply (3):</strong> Carrying out or using procedures<br>
                                <strong>Analyze (4):</strong> Breaking material into parts<br>
                                <strong>Evaluate (5):</strong> Making judgments based on criteria<br>
                                <strong>Create (6):</strong> Putting elements together to form something new
                            </p>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Create Bloom Level
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
