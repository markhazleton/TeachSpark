@model TeachSpark.Web.Data.Entities.BloomLevel

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">
                <i class="bi bi-diagram-3 text-primary"></i>
                Bloom Level Details
            </h1>
            <div>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header" style="background-color: @Model.ColorCode; color: white;">
                <h5 class="card-title mb-0">
                    <i class="bi bi-tag"></i>
                    @Model.Name (Level @Model.Order)
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-4">Order:</dt>
                            <dd class="col-sm-8">
                                <span class="badge bg-primary fs-6">@Model.Order</span>
                            </dd>
                            
                            <dt class="col-sm-4">Color Code:</dt>
                            <dd class="col-sm-8">
                                <span class="badge" style="background-color: @Model.ColorCode; color: white;">
                                    @Model.ColorCode
                                </span>
                            </dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-5">Worksheets:</dt>
                            <dd class="col-sm-7">
                                <span class="badge bg-info fs-6">@Model.Worksheets.Count</span>
                            </dd>
                        </dl>
                    </div>
                </div>

                <hr>

                <div class="mb-4">
                    <h6><i class="bi bi-card-text text-primary"></i> Description</h6>
                    <p class="lead">@Model.Description</p>
                </div>

                <div class="mb-4">
                    <h6><i class="bi bi-list-ul text-success"></i> Action Verbs</h6>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var verb in Model.ActionVerbs.Split(',', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <span class="badge bg-success">@verb.Trim()</span>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Examples))
                {
                    <div class="mb-4">
                        <h6><i class="bi bi-lightbulb text-warning"></i> Examples</h6>
                        <div class="bg-light p-3 rounded">
                            <p class="mb-0">@Model.Examples</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="bi bi-files text-info"></i>
                    Associated Worksheets (@Model.Worksheets.Count)
                </h6>
            </div>
            <div class="card-body">
                @if (Model.Worksheets.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var worksheet in Model.Worksheets.Take(10))
                        {
                            <div class="list-group-item px-0">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="ms-2 me-auto">
                                        <div class="fw-bold">
                                            <a asp-controller="Worksheets" asp-action="Details" asp-route-id="@worksheet.Id" class="text-decoration-none">
                                                @worksheet.Title
                                            </a>
                                        </div>
                                        <small class="text-muted">by @worksheet.User.Email</small>
                                    </div>
                                    <small class="text-muted">@worksheet.CreatedAt.ToString("MMM dd")</small>
                                </div>
                            </div>
                        }
                    </div>
                    
                    @if (Model.Worksheets.Count > 10)
                    {
                        <div class="text-center mt-3">
                            <a asp-controller="Worksheets" asp-action="Index" class="btn btn-sm btn-outline-info">
                                View All @Model.Worksheets.Count Worksheets
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-file-text display-6"></i>
                        <p class="mt-2 mb-0">No worksheets using this Bloom level yet.</p>
                    </div>
                }
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="bi bi-gear text-secondary"></i>
                    Actions
                </h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Edit This Bloom Level
                    </a>
                    <a asp-action="Create" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> Create New Bloom Level
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                        <i class="bi bi-trash"></i> Delete This Bloom Level
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
