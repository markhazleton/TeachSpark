@model IEnumerable<TeachSpark.Web.Data.Entities.BloomLevel>

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">
                <i class="bi bi-diagram-3 text-primary"></i>
                Bloom Levels Management
            </h1>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Bloom Level
            </a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-table"></i>
            Bloom Levels Overview
        </h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="bloomLevelsTable" class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Order</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Action Verbs</th>
                        <th>Color</th>
                        <th>Worksheets</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Data will be loaded via AJAX -->
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Get CSRF token
            var token = $('input[name="__RequestVerificationToken"]').val();
            
            $('#bloomLevelsTable').DataTable({
                ajax: {
                    url: '@Url.Action("GetBloomLevelsData")',
                    type: 'POST',
                    data: function(d) {
                        d.__RequestVerificationToken = token;
                        return d;
                    },
                    error: function(xhr, error, code) {
                        console.error('DataTables error:', error);
                        alert('Error loading data. Please refresh the page.');
                    }
                },
                columns: [
                    { 
                        data: 'order',
                        width: '60px',
                        className: 'text-center'
                    },
                    { 
                        data: 'name',
                        render: function(data, type, row) {
                            return '<strong>' + data + '</strong>';
                        }
                    },
                    { 
                        data: 'description',
                        width: '30%'
                    },
                    { 
                        data: 'actionVerbs',
                        width: '25%',
                        render: function(data, type, row) {
                            return '<small class="text-muted">' + (data || '') + '</small>';
                        }
                    },
                    { 
                        data: 'colorCode',
                        width: '80px',
                        className: 'text-center',
                        render: function(data, type, row) {
                            return '<span class="badge" style="background-color: ' + (data || '#6c757d') + '; color: white;">' + (data || 'N/A') + '</span>';
                        }
                    },
                    { 
                        data: 'worksheetCount',
                        width: '100px',
                        className: 'text-center',
                        render: function(data, type, row) {
                            return '<span class="badge bg-info">' + (data || 0) + '</span>';
                        }
                    },
                    {
                        data: 'id',
                        width: '150px',
                        className: 'text-center',
                        orderable: false,
                        render: function(data, type, row) {
                            return '<div class="btn-group btn-group-sm" role="group">' +
                                '<a href="@Url.Action("Details", "BloomLevels")/' + data + '" class="btn btn-outline-info btn-sm" title="Details">' +
                                '<i class="bi bi-eye"></i>' +
                                '</a>' +
                                '<a href="@Url.Action("Edit", "BloomLevels")/' + data + '" class="btn btn-outline-warning btn-sm" title="Edit">' +
                                '<i class="bi bi-pencil"></i>' +
                                '</a>' +
                                '<a href="@Url.Action("Delete", "BloomLevels")/' + data + '" class="btn btn-outline-danger btn-sm" title="Delete">' +
                                '<i class="bi bi-trash"></i>' +
                                '</a>' +
                                '</div>';
                        }
                    }
                ],                order: [[0, 'asc']], // Sort by order column
                pageLength: 25,
                responsive: true,
                processing: true,
                language: {
                    search: "Search Bloom Levels:",
                    lengthMenu: "Show _MENU_ bloom levels per page",
                    info: "Showing _START_ to _END_ of _TOTAL_ bloom levels",
                    infoEmpty: "No bloom levels found",
                    zeroRecords: "No matching bloom levels found",
                    processing: "Loading bloom levels..."
                }
            });
        });
    </script>
}

<form method="post" style="display: none;">
    @Html.AntiForgeryToken()
</form>
