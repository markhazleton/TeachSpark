@model IEnumerable<TeachSpark.Web.Data.Entities.AcademicStandard>

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">
                <i class="bi bi-mortarboard text-primary"></i>
                Academic Standards Management
            </h1>
            <div>
                <form asp-action="RefreshFromCsv" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success"
                        onclick="return confirm('This will replace all existing data with fresh data from the CSV file. Are you sure?')">
                        <i class="bi bi-arrow-clockwise"></i> Refresh from CSV
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-table"></i>
            Academic Standards Overview
        </h5>
    </div>
    <div class="card-body">
        <!-- Advanced Filters -->
        <div class="row mb-4">
            <div class="col-md-3">
                <label for="subjectFilter" class="form-label">Filter by Subject:</label>
                <select id="subjectFilter" class="form-select">
                    <option value="">All Subjects</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="gradeFilter" class="form-label">Filter by Grade:</label>
                <select id="gradeFilter" class="form-select">
                    <option value="">All Grades</option>
                </select>
            </div>
            <div class="col-md-4">
                <label for="customSearch" class="form-label">Search Standards:</label>
                <input type="text" id="customSearch" class="form-control"
                    placeholder="Search by GLE code, statement, or subheading...">
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button id="clearFilters" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-circle"></i> Clear
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table id="standardsTable" class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Subject</th>
                        <th>Grade</th>
                        <th>GLE Code</th>
                        <th>Statement</th>
                        <th>Subheading</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Data will be loaded via AJAX -->
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function ()
        {
            var table = $('#standardsTable').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "@Url.Action("GetStandardsData")",
                    "type": "POST",
                    "headers": {
                        "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                    },
                    "data": function (d)
                    {
                        // Add custom filter parameters
                        d.subjectFilter = $('#subjectFilter').val();
                        d.gradeFilter = $('#gradeFilter').val();
                        d.customSearch = $('#customSearch').val();
                    }
                },
                "columns": [
                    { 
                        "data": "subject", 
                        "name": "Subject",
                        "render": function (data, type, row) {
                            if (type === 'display') {
                                return '<a href="@Url.Action("Details")/' + row.id + '" class="text-primary fw-bold">' + data + '</a>';
                            }
                            return data;
                        }
                    },
                    { "data": "grade", "name": "Grade" },
                    { 
                        "data": "gleCode", 
                        "name": "GleCode",
                        "render": function (data, type, row) {
                            if (type === 'display') {
                                return '<a href="@Url.Action("Details")/' + row.id + '" class="text-primary">' + data + '</a>';
                            }
                            return data;
                        }
                    },
                    {
                        "data": "statement",
                        "name": "Statement",
                        "orderable": true,
                        "render": function (data, type, row)
                        {
                            if (type === 'display' && data.length > 120)
                            {
                                return '<span title="' + data + '">' + data.substr(0, 120) + '...</span>';
                            }
                            return data;
                        }
                    },
                    {
                        "data": "subheading",
                        "name": "Subheading",
                        "orderable": false,
                        "render": function (data, type, row)
                        {
                            if (type === 'display' && data && data.length > 60)
                            {
                                return '<span title="' + data + '">' + data.substr(0, 60) + '...</span>';
                            }
                            return data || '';
                        }
                    }
                ],
                "order": [[0, "asc"], [1, "asc"]],
                "pageLength": 25,
                "lengthMenu": [[10, 25, 50, 100], [10, 25, 50, 100]],
                "language": {
                    "emptyTable": "No academic standards found. Click 'Refresh from CSV' to load data.",
                    "zeroRecords": "No matching academic standards found.",
                    "info": "Showing _START_ to _END_ of _TOTAL_ standards",
                    "infoEmpty": "Showing 0 to 0 of 0 standards",
                    "infoFiltered": "(filtered from _MAX_ total standards)"
                },
                "dom": '<"row"<"col-sm-12 col-md-6"l><"col-sm-12 col-md-6"f>>' +
                    '<"row"<"col-sm-12"tr>>' +
                    '<"row"<"col-sm-12 col-md-5"i><"col-sm-12 col-md-7"p>>',
                "responsive": true,
                "searching": false, // Disable default search since we have custom filters
                "stateSave": true, // Remember user preferences
                "rowCallback": function(row, data) {
                    // Add cursor pointer to entire row for better UX
                    $(row).css('cursor', 'pointer');
                    $(row).on('click', function(e) {
                        // Only navigate if not clicking on a link
                        if (!$(e.target).is('a')) {
                            window.location.href = '@Url.Action("Details")/' + data.id;
                        }
                    });
                }
            });

            // Load filter options
            loadFilterOptions();

            // Custom filter event handlers
            $('#subjectFilter, #gradeFilter').on('change', function ()
            {
                table.draw();
            });

            $('#customSearch').on('keyup', function ()
            {
                clearTimeout(window.searchTimeout);
                window.searchTimeout = setTimeout(function ()
                {
                    table.draw();
                }, 300); // Debounce search
            });

            // Clear filters
            $('#clearFilters').on('click', function ()
            {
                $('#subjectFilter').val('');
                $('#gradeFilter').val('');
                $('#customSearch').val('');
                table.draw();
            });

            // Function to load filter options
            function loadFilterOptions()
            {
                $.ajax({
                    url: '@Url.Action("GetFilterOptions")',
                    type: 'GET',
                    success: function (data)
                    {
                        // Populate subject filter
                        var subjectSelect = $('#subjectFilter');
                        subjectSelect.empty().append('<option value="">All Subjects</option>');
                        $.each(data.subjects, function (index, subject)
                        {
                            subjectSelect.append('<option value="' + subject + '">' + subject + '</option>');
                        });

                        // Populate grade filter
                        var gradeSelect = $('#gradeFilter');
                        gradeSelect.empty().append('<option value="">All Grades</option>');
                        $.each(data.grades, function (index, grade)
                        {
                            gradeSelect.append('<option value="' + grade + '">' + grade + '</option>');
                        });
                    },
                    error: function ()
                    {
                        console.log('Failed to load filter options');
                    }
                });
            }
        });
    </script>
}