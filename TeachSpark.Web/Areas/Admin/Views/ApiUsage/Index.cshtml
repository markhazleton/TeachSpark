@{
    ViewData["Title"] = "API Usage Analytics";
    ViewData["PageHeader"] = "API Usage Analytics";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">API Usage</h2>
            <p class="text-muted">Monitor API usage and performance metrics</p>
        </div>
    </div>

    <!-- Usage Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0" id="totalRequests">-</h4>
                            <p class="mb-0">Total Requests</p>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-graph-up-arrow fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0" id="successfulRequests">-</h4>
                            <p class="mb-0">Successful (2xx)</p>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-check-circle fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0" id="errorRequests">-</h4>
                            <p class="mb-0">Errors (4xx/5xx)</p>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-exclamation-triangle fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0" id="avgResponseTime">-</h4>
                            <p class="mb-0">Avg Response (ms)</p>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-speedometer2 fs-2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">
                <i class="bi bi-list-ul me-2"></i>API Usage Log
            </h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="apiUsageTable" class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>API Key</th>
                            <th>Endpoint</th>
                            <th>Method</th>
                            <th>Status</th>
                            <th>Response Time</th>
                            <th>IP Address</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- DataTables will populate this -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function ()
        {
            // Load statistics
            loadStatistics();

            // Initialize DataTable            $('#apiUsageTable').DataTable({
            ajax: {
                url: '@Url.Action("GetApiUsageData")',
                    type: 'POST',
                        data: function(d)
                        {
                            d.__RequestVerificationToken = $('input[name="__RequestVerificationToken"]').val();
                            return d;
                        },
                error: function(xhr, error, code)
                {
                    console.log('DataTables AJAX error:', error);
                    alert('Error loading data. Please refresh the page and try again.');
                }
            },
            processing: true,
                columns: [
                    {
                        data: 'requestedAt',
                        title: 'Timestamp',
                        render: function (data)
                        {
                            return new Date(data).toLocaleString();
                        }
                    },
                    {
                        data: 'apiKeyName',
                        title: 'API Key',
                        render: function (data, type, row)
                        {
                            return data + ' (' + row.apiKeyPrefix + '...)';
                        }
                    },
                    { data: 'endpoint', title: 'Endpoint' },
                    {
                        data: 'httpMethod',
                        title: 'Method',
                        render: function (data)
                        {
                            const colors = {
                                'GET': 'success',
                                'POST': 'primary',
                                'PUT': 'warning',
                                'DELETE': 'danger'
                            };
                            return '<span class="badge bg-' + (colors[data] || 'secondary') + '">' + data + '</span>';
                        }
                    },
                    {
                        data: 'responseStatusCode',
                        title: 'Status',
                        render: function (data)
                        {
                            let badgeClass = 'secondary';
                            if (data >= 200 && data < 300) badgeClass = 'success';
                            else if (data >= 400 && data < 500) badgeClass = 'warning';
                            else if (data >= 500) badgeClass = 'danger';

                            return '<span class="badge bg-' + badgeClass + '">' + data + '</span>';
                        }
                    },
                    {
                        data: 'responseTime',
                        title: 'Response Time',
                        render: function (data)
                        {
                            // Assuming data is in ticks, convert to milliseconds
                            const ms = data / 10000; // Convert ticks to milliseconds
                            return ms.toFixed(0) + ' ms';
                        }
                    },
                    { data: 'ipAddress', title: 'IP Address' },
                    {
                        data: 'id',
                        title: 'Actions',
                        orderable: false,
                        render: function (data)
                        {
                            return `
                                    <a href="@Url.Action("Details")/${data}" class="btn btn-sm btn-outline-info" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                `;
                        }
                    }
                ],
                    order: [[0, 'desc']], // Sort by timestamp descending
                        pageLength: 25,
                            responsive: true,
                                language: {
                emptyTable: "No API usage records found",
                    zeroRecords: "No matching usage records found"
            }
        });
            });

        function loadStatistics()
        {
            // This would typically load from an API endpoint
            fetch('@Url.Action("GetStatistics")')
                .then(response => response.json())
                .then(data =>
                {
                    document.getElementById('totalRequests').textContent = data.totalRequests || '0';
                    document.getElementById('successfulRequests').textContent = data.successfulRequests || '0';
                    document.getElementById('errorRequests').textContent = data.errorRequests || '0';
                    document.getElementById('avgResponseTime').textContent = (data.avgResponseTime || 0) + ' ms';
                })
                .catch(error =>
                {
                    console.error('Error loading statistics:', error);
                });
        }
    </script>
}
 
           
