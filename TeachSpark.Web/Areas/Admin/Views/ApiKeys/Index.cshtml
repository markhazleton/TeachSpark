@{
    ViewData["Title"] = "API Keys Management";
    ViewData["PageHeader"] = "API Keys Management";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">API Keys</h2>
            <p class="text-muted">Manage API keys for external access</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Create New API Key
        </a>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="card-title mb-0">
                <i class="bi bi-key me-2"></i>API Keys List
            </h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="apiKeysTable" class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Key Prefix</th>
                            <th>Owner</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Expires</th>
                            <th>Usage</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- DataTables will populate this -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function ()
        {
            $('#apiKeysTable').DataTable({
                ajax: {
                    url: '@Url.Action("GetApiKeysData")',
                    type: 'POST',
                    data: function (d)
                    {
                        d.__RequestVerificationToken = $('input[name="__RequestVerificationToken"]').val();
                        return d;
                    },
                    error: function (xhr, error, code)
                    {
                        console.log('DataTables AJAX error:', error);
                        alert('Error loading data. Please refresh the page and try again.');
                    }
                },
                processing: true,
                columns: [
                    { data: 'name', title: 'Name' },
                    {
                        data: 'keyPrefix',
                        title: 'Key Prefix',
                        render: function (data)
                        {
                            return '<code>' + data + '...</code>';
                        }
                    },
                    {
                        data: 'userName',
                        title: 'Owner',
                        render: function (data)
                        {
                            return data || 'System';
                        }
                    },
                    {
                        data: 'isActive',
                        title: 'Status',
                        render: function (data)
                        {
                            return data
                                ? '<span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>'
                                : '<span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Inactive</span>';
                        }
                    },
                    {
                        data: 'createdAt',
                        title: 'Created',
                        render: function (data)
                        {
                            return new Date(data).toLocaleDateString();
                        }
                    },
                    {
                        data: 'expiresAt',
                        title: 'Expires',
                        render: function (data)
                        {
                            if (!data) return '<span class="text-muted">Never</span>';
                            const expiry = new Date(data);
                            const now = new Date();
                            const isExpired = expiry < now;
                            return isExpired
                                ? '<span class="text-danger">Expired</span>'
                                : expiry.toLocaleDateString();
                        }
                    },
                    {
                        data: 'requestCount',
                        title: 'Usage',
                        render: function (data, type, row)
                        {
                            const percentage = row.dailyRequestLimit > 0
                                ? (data / row.dailyRequestLimit * 100).toFixed(1)
                                : 0;
                            return data + '/' + row.dailyRequestLimit + ' (' + percentage + '%)';
                        }
                    },
                    {
                        data: 'id',
                        title: 'Actions',
                        orderable: false,
                        render: function (data)
                        {
                            return `
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a href="@Url.Action("Details")/${data}" class="btn btn-outline-info" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit")/${data}" class="btn btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a href="@Url.Action("Delete")/${data}" class="btn btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                `;
                        }
                    }
                ],
                order: [[4, 'desc']], // Sort by created date descending
                pageLength: 25,
                responsive: true,
                language: {
                    emptyTable: "No API keys found",
                    zeroRecords: "No matching API keys found"
                }
            });
        });
    </script>
}
 
       
 
                    
                    
                        
                        
                        
                        
                        
                        
                                                                       