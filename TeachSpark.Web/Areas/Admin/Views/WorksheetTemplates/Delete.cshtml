@model TeachSpark.Web.Data.Entities.WorksheetTemplate

@{
    ViewData["Title"] = "Delete Worksheet Template";
    ViewData["PageHeader"] = "Delete Worksheet Template";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>Confirm Deletion
                    </h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Warning:</strong> You are about to permanently delete this worksheet template. This
                        action cannot be undone.
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tbody>
                                    <tr>
                                        <td class="fw-bold text-muted">Name:</td>
                                        <td>@Model.Name</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold text-muted">Type:</td>
                                        <td>
                                            <span class="badge bg-info">@Model.TemplateType</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold text-muted">Created:</td>
                                        <td>@Model.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold text-muted">Usage Count:</td>
                                        <td>
                                            <span class="badge bg-success">@Model.UsageCount</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold text-muted">Creator:</td>
                                        <td>@(Model.User?.Email ?? "System")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tbody>
                                    <tr>
                                        <td class="fw-bold text-muted">Visibility:</td>
                                        <td>
                                            @if (Model.IsPublic)
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-globe me-1"></i>Public
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">
                                                    <i class="bi bi-lock me-1"></i>Private
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold text-muted">Type:</td>
                                        <td>
                                            @if (Model.IsSystem)
                                            {
                                                <span class="badge bg-primary">
                                                    <i class="bi bi-gear me-1"></i>System
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">
                                                    <i class="bi bi-person me-1"></i>User Created
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold text-muted">Worksheets:</td>
                                        <td>
                                            <span class="badge bg-warning text-dark">@Model.Worksheets.Count</span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="mt-3">
                            <h6 class="fw-bold text-muted">Description:</h6>
                            <div class="border-start border-4 border-primary ps-3">
                                <p class="mb-0">@Model.Description</p>
                            </div>
                        </div>
                    }

                    @if (Model.Worksheets.Any())
                    {
                        <div class="alert alert-danger mt-4" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <strong>Impact Warning:</strong> This template is currently used in
                            <strong>@Model.Worksheets.Count</strong> worksheet(s).
                            Deleting this template may affect those worksheets and could cause data integrity issues.
                        </div>
                    }

                    <form asp-action="Delete" method="post" class="mt-4">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Cancel
                            </a>
                            <div>
                                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info me-2">
                                    <i class="bi bi-eye me-1"></i>View Details
                                </a>
                                <button type="submit" class="btn btn-danger"
                                    onclick="return confirm('Are you absolutely sure you want to delete this worksheet template? This action cannot be undone.')">
                                    <i class="bi bi-trash me-1"></i>Delete Template
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add extra confirmation for dangerous deletions
        document.addEventListener('DOMContentLoaded', function ()
        {
            const deleteForm = document.querySelector('form[asp-action="Delete"]');
            if (deleteForm)
            {
                deleteForm.addEventListener('submit', function (e)
                {
                    const hasWorksheets = @(Model.Worksheets.Any() ? "true" : "false");
                    if (hasWorksheets)
                    {
                        const doubleConfirm = confirm('FINAL WARNING: This template has associated worksheets. Are you ABSOLUTELY CERTAIN you want to proceed with deletion?');
                        if (!doubleConfirm)
                        {
                            e.preventDefault();
                            return false;
                        }
                    }
                });
            }
        });
    </script>
}

                       
                           
                                    
       
            
               
                   
                       