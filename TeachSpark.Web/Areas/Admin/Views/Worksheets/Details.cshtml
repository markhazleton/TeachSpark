@model TeachSpark.Web.Data.Entities.Worksheet

@{
    ViewData["Title"] = $"Worksheet Details - {Model.Title}";
    ViewData["PageHeader"] = "Worksheet Details";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="bi bi-file-text me-2"></i>@Model.Title
        </h2>
        <div class="btn-group" role="group">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                <i class="bi bi-trash me-1"></i>Delete
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <!-- Basic Information -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-info-circle me-2"></i>Basic Information
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">ID:</h6>
                                <p class="mb-0">@Model.Id</p>
                            </div>
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Title:</h6>
                                <p class="mb-0">@Model.Title</p>
                            </div>
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Description:</h6>
                                <p class="mb-0">@(string.IsNullOrEmpty(Model.Description) ? "No description provided" : Model.Description)</p>
                            </div>
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">User:</h6>
                                <p class="mb-0">@(Model.User?.Email ?? "Unknown")</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Worksheet Type:</h6>
                                <span class="badge bg-primary">@Model.WorksheetType.Replace("-", " ").Replace("_", " ")</span>
                            </div>
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Difficulty Level:</h6>
                                @{
                                    var difficultyColor = Model.DifficultyLevel switch
                                    {
                                        "simplified" => "success",
                                        "standard" => "primary",
                                        "advanced" => "warning",
                                        _ => "secondary"
                                    };
                                }
                                <span class="badge bg-@difficultyColor">@Model.DifficultyLevel.First().ToString().ToUpper()@Model.DifficultyLevel.Substring(1)</span>
                            </div>
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Status:</h6>
                                @if (Model.IsPublic)
                                {
                                    <span class="badge bg-success"><i class="bi bi-globe me-1"></i>Public</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="bi bi-lock me-1"></i>Private</span>
                                }
                                @if (Model.IsFavorite)
                                {
                                    <span class="badge bg-warning ms-1"><i class="bi bi-star-fill me-1"></i>Favorite</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Standards & Classifications -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-bookmark me-2"></i>Standards & Classifications
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Common Core Standard:</h6>
                                @if (Model.CommonCoreStandard != null)
                                {
                                    <span class="badge bg-info">@Model.CommonCoreStandard.Code</span>
                                    <p class="small text-muted mt-1">@Model.CommonCoreStandard.Description</p>
                                }
                                else
                                {
                                    <span class="text-muted">Not specified</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Academic Standard:</h6>
                                @if (Model.AcademicStandard != null)
                                {
                                    <span class="badge bg-info">@Model.AcademicStandard.GleCode</span>
                                    <p class="small text-muted mt-1">@Model.AcademicStandard.Statement</p>
                                }
                                else
                                {
                                    <span class="text-muted">Not specified</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Bloom's Level:</h6>
                                @if (Model.BloomLevel != null)
                                {
                                    <span class="badge" style="background-color: @Model.BloomLevel.ColorCode">@Model.BloomLevel.Name</span>
                                    <p class="small text-muted mt-1">@Model.BloomLevel.Description</p>
                                }
                                else
                                {
                                    <span class="text-muted">Not specified</span>
                                }
                            </div>
                        </div>
                    </div>

                    @if (Model.Template != null)
                    {
                        <div class="mb-3">
                            <h6 class="fw-bold text-muted">Template:</h6>
                            <span class="badge bg-secondary">@Model.Template.Name</span>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Tags))
                    {
                        <div class="mb-3">
                            <h6 class="fw-bold text-muted">Tags:</h6>
                            @foreach (var tag in Model.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="badge bg-light text-dark me-1">@tag.Trim()</span>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Content -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-file-text me-2"></i>Content
                    </h5>
                    <div class="btn-group btn-group-sm" role="group">
                        <button class="btn btn-outline-secondary" onclick="showMarkdown()">Markdown</button>
                        <button class="btn btn-outline-secondary" onclick="showHtml()">HTML Preview</button>
                    </div>
                </div>
                <div class="card-body">
                    <div id="markdownContent" style="display: none;">
                        <h6 class="fw-bold">Markdown Source:</h6>
                        <pre class="bg-light p-3 rounded"><code>@Model.ContentMarkdown</code></pre>
                    </div>
                    
                    <div id="htmlContent">
                        <h6 class="fw-bold">Rendered Content:</h6>
                        <div class="border p-3 rounded bg-white">
                            @if (!string.IsNullOrEmpty(Model.RenderedHtml))
                            {
                                @Html.Raw(Model.RenderedHtml)
                            }
                            else
                            {
                                <div class="text-muted">No rendered HTML available</div>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.SourceText))
                    {
                        <div class="mt-3">
                            <h6 class="fw-bold">Source Text:</h6>
                            <div class="bg-light p-3 rounded">
                                @Model.SourceText
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <!-- Statistics -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-graph-up me-2"></i>Statistics
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6">
                            <div class="mb-3">
                                <h3 class="text-primary">@Model.ViewCount</h3>
                                <small class="text-muted">Views</small>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="mb-3">
                                <h3 class="text-success">@Model.DownloadCount</h3>
                                <small class="text-muted">Downloads</small>
                            </div>
                        </div>
                    </div>
                    
                    <hr>
                    
                    <div class="mb-2">
                        <strong>Created:</strong> @Model.CreatedAt.ToString("MMM dd, yyyy 'at' HH:mm")
                    </div>
                    <div class="mb-2">
                        <strong>Updated:</strong> @Model.UpdatedAt.ToString("MMM dd, yyyy 'at' HH:mm")
                    </div>
                    @if (Model.LastAccessedAt.HasValue)
                    {
                        <div class="mb-2">
                            <strong>Last Accessed:</strong> @Model.LastAccessedAt.Value.ToString("MMM dd, yyyy 'at' HH:mm")
                        </div>
                    }
                </div>
            </div>

            <!-- LLM Generation Metadata -->
            @if (!string.IsNullOrEmpty(Model.LlmModel))
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-robot me-2"></i>LLM Generation Data
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <h6 class="fw-bold text-muted">Model:</h6>
                            <span class="badge bg-info">@Model.LlmModel</span>
                        </div>

                        @if (Model.GenerationCost.HasValue)
                        {
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Generation Cost:</h6>
                                <span class="badge bg-success">$@Model.GenerationCost.Value.ToString("F4")</span>
                            </div>
                        }

                        @if (Model.TokensUsed.HasValue)
                        {
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Tokens Used:</h6>
                                <span class="badge bg-secondary">@Model.TokensUsed.Value.ToString("N0")</span>
                            </div>
                        }

                        @if (Model.ConfidenceScore.HasValue)
                        {
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Confidence Score:</h6>
                                @{
                                    var confidence = Math.Round(Model.ConfidenceScore.Value * 100);
                                    var confidenceColor = confidence >= 80 ? "success" : confidence >= 60 ? "warning" : "danger";
                                }
                                <span class="badge bg-@confidenceColor">@confidence%</span>
                            </div>
                        }

                        <div class="row">
                            <div class="col-6">
                                <div class="mb-3">
                                    <h6 class="fw-bold text-muted">Questions:</h6>
                                    <span class="badge bg-primary">@Model.QuestionCount</span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="mb-3">
                                    <h6 class="fw-bold text-muted">Duration:</h6>
                                    <span class="badge bg-secondary">@Model.EstimatedDurationMinutes min</span>
                                </div>
                            </div>
                        </div>

                        @if (Model.HasAnswerKey)
                        {
                            <div class="mb-3">
                                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Has Answer Key</span>
                            </div>
                        }

                        @if (Model.GenerationTime.HasValue)
                        {
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Generation Time:</h6>
                                <span class="text-muted">@Model.GenerationTime.Value.TotalSeconds.ToString("F1")s</span>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.GenerationPrompt))
                        {
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted">Generation Prompt:</h6>
                                <div class="bg-light p-2 rounded small">
                                    @Model.GenerationPrompt
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.Warnings))
                        {
                            <div class="mb-3">
                                <h6 class="fw-bold text-muted text-warning">Warnings:</h6>
                                <div class="bg-warning bg-opacity-10 p-2 rounded small">
                                    @try
                                    {
                                        var warnings = System.Text.Json.JsonSerializer.Deserialize<string[]>(Model.Warnings);
                                        if (warnings != null)
                                        {
                                            <ul class="mb-0">
                                                @foreach (var warning in warnings)
                                                {
                                                    <li>@warning</li>
                                                }
                                            </ul>
                                        }
                                    }
                                    catch
                                    {
                                        <span>@Model.Warnings</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Export History -->
            @if (Model.Exports.Any())
            {
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-download me-2"></i>Export History
                        </h5>
                    </div>
                    <div class="card-body">
                        @foreach (var export in Model.Exports.OrderByDescending(e => e.CreatedAt))
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div>
                                    <span class="badge bg-secondary">@export.ExportFormat.ToUpper()</span>
                                    <small class="text-muted ms-2">@export.CreatedAt.ToString("MMM dd, HH:mm")</small>
                                </div>
                                <small class="text-muted">@export.DownloadCount downloads</small>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showMarkdown() {
            document.getElementById('markdownContent').style.display = 'block';
            document.getElementById('htmlContent').style.display = 'none';
        }

        function showHtml() {
            document.getElementById('markdownContent').style.display = 'none';
            document.getElementById('htmlContent').style.display = 'block';
        }
    </script>
}
