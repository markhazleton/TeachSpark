@model IEnumerable<TeachSpark.Web.Data.Entities.CommonCoreStandard>

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">
                <i class="bi bi-bookmarks text-primary"></i>
                Common Core Standards Management
            </h1>
            <div class="btn-group" role="group">
                <a asp-action="ImportCsv" class="btn btn-success">
                    <i class="bi bi-upload"></i> Import CSV
                </a>
                <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#importDefaultModal">
                    <i class="bi bi-database-fill-up"></i> Load Default Data
                </button>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Add New Standard
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">
            <i class="bi bi-table"></i>
            Common Core Standards Overview
        </h5>
        <div class="text-muted small">
            <kbd>Ctrl+K</kbd> to search • <kbd>Ctrl+R</kbd> to clear filters
        </div>
    </div>
    <div class="card-body">
        <!-- Advanced Filters -->
        <div class="row mb-3">
            <div class="col-md-3">
                <label for="gradeFilter" class="form-label">Grade Level</label>
                <select id="gradeFilter" class="form-select">
                    <option value="">All Grades</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="subjectFilter" class="form-label">Subject</label>
                <select id="subjectFilter" class="form-select">
                    <option value="">All Subjects</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="domainFilter" class="form-label">Domain</label>
                <select id="domainFilter" class="form-select">
                    <option value="">All Domains</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="statusFilter" class="form-label">Status</label>
                <select id="statusFilter" class="form-select">
                    <option value="">All Status</option>
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>
        </div>

        <!-- Summary Statistics -->
        <div class="row mb-3" id="summaryStats" style="display: none;">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h5 class="card-title" id="totalStandards">0</h5>
                        <p class="card-text">Total Standards</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <h5 class="card-title" id="activeStandards">0</h5>
                        <p class="card-text">Active Standards</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body text-center">
                        <h5 class="card-title" id="uniqueGrades">0</h5>
                        <p class="card-text">Grade Levels</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body text-center">
                        <h5 class="card-title" id="uniqueDomains">0</h5>
                        <p class="card-text">Domains</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="table-responsive">
            <!-- Loading placeholder -->
            <div id="loadingPlaceholder" class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2 text-muted">Loading Common Core Standards...</p>
            </div>

            <table id="standardsTable" class="table table-striped table-hover" style="display: none;">
                <thead class="table-dark">
                    <tr>
                        <th>Code</th>
                        <th>Grade</th>
                        <th>Subject</th>
                        <th>Domain</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Worksheets</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Data will be loaded via AJAX -->
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function ()
        {
            // Get CSRF token
            var token = $('input[name="__RequestVerificationToken"]').val();
            var table;

            // Initialize DataTable
            table = $('#standardsTable').DataTable({
                ajax: {
                    url: '@Url.Action("GetStandardsData")',
                    type: 'POST',
                    data: function (d)
                    {
                        d.__RequestVerificationToken = token;
                        return d;
                    },
                    error: function (xhr, error, code)
                    {
                        console.error('DataTables error:', error);
                        alert('Error loading data. Please refresh the page.');
                    }, dataSrc: function (json)
                    {
                        // Hide loading placeholder and show table
                        $('#loadingPlaceholder').hide();
                        $('#standardsTable').show();

                        // Populate filter dropdowns and summary stats after data is loaded
                        populateFilters(json.data);
                        updateSummaryStats(json.data);
                        return json.data;
                    }
                },
                columns: [
                    {
                        data: 'code',
                        render: function (data, type, row)
                        {
                            var detailsUrl = '@Url.Action("Details", "CommonCoreStandards")/' + row.id;
                            return '<a href="' + detailsUrl + '" class="text-decoration-none"><code class="text-primary fw-bold">' + (data || '') + '</code></a>';
                        }
                    },
                    {
                        data: 'grade',
                        width: '80px',
                        className: 'text-center'
                    },
                    {
                        data: 'subject',
                        width: '120px'
                    },
                    {
                        data: 'domain',
                        width: '140px'
                    },
                    {
                        data: 'category',
                        render: function (data, type, row)
                        {
                            return data ? '<span class="badge bg-secondary">' + data + '</span>' : '';
                        }
                    },
                    {
                        data: 'description',
                        width: '35%',
                        render: function (data, type, row)
                        {
                            if (type === 'display' && data && data.length > 100)
                            {
                                return '<span title="' + data + '">' + data.substr(0, 100) + '...</span>';
                            }
                            return data || '';
                        }
                    },
                    {
                        data: 'isActive',
                        width: '80px',
                        className: 'text-center',
                        render: function (data, type, row)
                        {
                            return data ?
                                '<span class="badge bg-success">Active</span>' :
                                '<span class="badge bg-secondary">Inactive</span>';
                        }
                    },
                    {
                        data: 'worksheetCount',
                        width: '100px',
                        className: 'text-center',
                        render: function (data, type, row)
                        {
                            return '<span class="badge bg-info">' + (data || 0) + '</span>';
                        }
                    }
                ], order: [[3, 'asc'], [1, 'asc'], [0, 'asc']], // Sort by domain, then grade, then code
                pageLength: 50,
                lengthMenu: [[25, 50, 100, 200, -1], [25, 50, 100, 200, "All"]],
                responsive: true,
                processing: true,
                stateSave: true,
                language: {
                    search: "Search Standards:",
                    lengthMenu: "Show _MENU_ standards per page",
                    info: "Showing _START_ to _END_ of _TOTAL_ standards",
                    infoEmpty: "No standards found",
                    infoFiltered: "(filtered from _MAX_ total standards)",
                    zeroRecords: "No matching standards found",
                    processing: "Loading standards..."
                },
                dom: 'Bfrtip',
                buttons: [
                    'copy',
                    'csv',
                    'excel',
                    'pdf',
                    'print',
                    {
                        text: 'Clear Filters',
                        action: function ()
                        {
                            clearAllFilters();
                        }
                    }
                ]
            });            // Populate filter dropdowns
            function populateFilters(data)
            {
                var grades = [...new Set(data.map(item => item.grade).filter(grade => grade))].sort();
                var subjects = [...new Set(data.map(item => item.subject).filter(subject => subject))].sort();
                var domains = [...new Set(data.map(item => item.domain).filter(domain => domain))].sort();

                // Populate Grade filter
                $('#gradeFilter').empty().append('<option value="">All Grades</option>');
                grades.forEach(function (grade)
                {
                    $('#gradeFilter').append('<option value="' + grade + '">' + grade + '</option>');
                });

                // Populate Subject filter
                $('#subjectFilter').empty().append('<option value="">All Subjects</option>');
                subjects.forEach(function (subject)
                {
                    $('#subjectFilter').append('<option value="' + subject + '">' + subject + '</option>');
                });

                // Populate Domain filter
                $('#domainFilter').empty().append('<option value="">All Domains</option>');
                domains.forEach(function (domain)
                {
                    $('#domainFilter').append('<option value="' + domain + '">' + domain + '</option>');
                });
            }

            // Update summary statistics
            function updateSummaryStats(data)
            {
                var totalStandards = data.length;
                var activeStandards = data.filter(item => item.isActive).length;
                var uniqueGrades = [...new Set(data.map(item => item.grade).filter(grade => grade))].length;
                var uniqueDomains = [...new Set(data.map(item => item.domain).filter(domain => domain))].length;

                $('#totalStandards').text(totalStandards);
                $('#activeStandards').text(activeStandards);
                $('#uniqueGrades').text(uniqueGrades);
                $('#uniqueDomains').text(uniqueDomains);

                // Show the summary stats section
                $('#summaryStats').fadeIn();
            }

            // Filter functions
            function filterByGrade()
            {
                var grade = $('#gradeFilter').val();
                table.column(1).search(grade ? '^' + grade + '$' : '', true, false).draw();
            }

            function filterBySubject()
            {
                var subject = $('#subjectFilter').val();
                table.column(2).search(subject ? '^' + subject + '$' : '', true, false).draw();
            }

            function filterByDomain()
            {
                var domain = $('#domainFilter').val();
                table.column(3).search(domain ? '^' + domain + '$' : '', true, false).draw();
            }

            function filterByStatus()
            {
                var status = $('#statusFilter').val();
                if (status === '')
                {
                    table.column(6).search('').draw();
                } else
                {
                    var searchTerm = status === 'true' ? 'Active' : 'Inactive';
                    table.column(6).search(searchTerm).draw();
                }
            }

            function clearAllFilters()
            {
                $('#gradeFilter, #subjectFilter, #domainFilter, #statusFilter').val('');
                table.columns().search('').draw();
            }

            // Bind filter events
            $('#gradeFilter').on('change', filterByGrade);
            $('#subjectFilter').on('change', filterBySubject);
            $('#domainFilter').on('change', filterByDomain);
            $('#statusFilter').on('change', filterByStatus);

            // Add keyboard shortcuts
            $(document).on('keydown', function (e)
            {
                if (e.ctrlKey && e.key === 'k')
                {
                    e.preventDefault();
                    $('#standardsTable_filter input').focus();
                }
                if (e.ctrlKey && e.key === 'r')
                {
                    e.preventDefault();
                    clearAllFilters();
                }
            });
        });
    </script>
}

<form method="post" style="display: none;">
    @Html.AntiForgeryToken()
</form>

<!-- Import Default Data Modal -->
<div class="modal fade" id="importDefaultModal" tabindex="-1" aria-labelledby="importDefaultModalLabel"
    aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="ImportFromDefaultCsv" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="importDefaultModalLabel">
                        <i class="bi bi-database-fill-up"></i> Load Default Common Core Standards
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning" role="alert">
                        <i class="bi bi-exclamation-triangle"></i>
                        <strong>Warning:</strong> This will delete all existing Common Core Standards and replace them
                        with the default English Language Arts standards from the included CSV file.
                    </div>

                    <div class="mb-3">
                        <label for="defaultSubject" class="form-label">Default Subject</label>
                        <input type="text" class="form-control" id="defaultSubject" name="defaultSubject"
                            value="English Language Arts" required>
                        <div class="form-text">This subject will be assigned to all imported standards.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-database-fill-up"></i> Load Default Data
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>