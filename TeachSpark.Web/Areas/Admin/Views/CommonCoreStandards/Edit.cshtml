@model TeachSpark.Web.Data.Entities.CommonCoreStandard

@{
    ViewData["Title"] = "Edit Common Core Standard";
    ViewData["PageHeader"] = "Edit Common Core Standard";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Edit Common Core Standard
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" class="needs-validation" novalidate>
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Code" class="form-label">Code <span class="text-danger">*</span></label>
                                    <input asp-for="Code" class="form-control" placeholder="e.g., CCSS.ELA-LITERACY.RL.8.1" required />
                                    <div class="invalid-feedback">
                                        Please provide a valid code.
                                    </div>
                                    <span asp-validation-for="Code" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label asp-for="Grade" class="form-label">Grade <span class="text-danger">*</span></label>
                                    <input asp-for="Grade" class="form-control" placeholder="e.g., 8" required />
                                    <div class="invalid-feedback">
                                        Please provide a valid grade.
                                    </div>
                                    <span asp-validation-for="Grade" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label asp-for="SortOrder" class="form-label">Sort Order</label>
                                    <input asp-for="SortOrder" class="form-control" type="number" min="0" />
                                    <span asp-validation-for="SortOrder" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Subject" class="form-label">Subject <span class="text-danger">*</span></label>
                                    <input asp-for="Subject" class="form-control" placeholder="e.g., English Language Arts" required />
                                    <div class="invalid-feedback">
                                        Please provide a valid subject.
                                    </div>
                                    <span asp-validation-for="Subject" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Domain" class="form-label">Domain <span class="text-danger">*</span></label>
                                    <input asp-for="Domain" class="form-control" placeholder="e.g., Reading Literature" required />
                                    <div class="invalid-feedback">
                                        Please provide a valid domain.
                                    </div>
                                    <span asp-validation-for="Domain" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Category" class="form-label">Category</label>
                            <input asp-for="Category" class="form-control" placeholder="e.g., Key Ideas and Details" />
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe the standard..." required></textarea>
                            <div class="invalid-feedback">
                                Please provide a description.
                            </div>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ExampleActivities" class="form-label">Example Activities</label>
                            <textarea asp-for="ExampleActivities" class="form-control" rows="3" placeholder="Provide example activities or exercises..."></textarea>
                            <span asp-validation-for="ExampleActivities" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label">
                                Is Active
                            </label>
                            <div class="form-text">Inactive standards will be hidden from selection lists.</div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Back to List
                            </a>
                            <div>
                                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info me-2">
                                    <i class="bi bi-eye me-1"></i>View Details
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-lg me-1"></i>Update Standard
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="bi bi-info-circle me-2"></i>Editing Guidelines
                    </h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success me-2"></i>
                            <strong>Code:</strong> Use official Common Core format
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success me-2"></i>
                            <strong>Grade:</strong> Enter the target grade level
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success me-2"></i>
                            <strong>Description:</strong> Be clear and comprehensive
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle text-success me-2"></i>
                            <strong>Activities:</strong> Provide practical examples
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Bootstrap form validation
        (function() {
            'use strict';
            const forms = document.querySelectorAll('.needs-validation');
            Array.prototype.slice.call(forms).forEach(function(form) {
                form.addEventListener('submit', function(event) {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
}
