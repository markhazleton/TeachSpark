{
    "ConnectionStrings": {
        "DefaultConnection": "Data Source=c:\\websites\\teachspark\\teachspark.db"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "LlmConfiguration": {
        "Provider": "OpenAI",
        "DefaultModel": "gpt-4o-mini",
        "MaxTokens": 4000,
        "Temperature": 0.7,
        "TimeoutSeconds": 60,
        "MaxRetries": 3,
        "MaxCostPerRequest": 1.0,
        "DailyCostLimit": 50.0,
        "RequestsPerMinute": 20,
        "RequestsPerDay": 1000,
        "EnableCaching": true,
        "CacheExpirationMinutes": 60
    },
    "WorksheetGeneration": {
        "DefaultQuestionCount": 10,
        "MaxQuestionCount": 25,
        "SupportedWorksheetTypes": [
            "reading-comprehension",
            "vocabulary",
            "grammar",
            "creative-writing",
            "literary-analysis"
        ],
        "SupportedDifficultyLevels": ["simplified", "standard", "advanced"],
        "EnableContentValidation": true,
        "RequireStandardsAlignment": true
    }
}
